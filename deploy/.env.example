# Connect full-stack deployment — environment.
#
# Copy to `.env` (docker compose reads it automatically) and replace the placeholder
# tokens with real secrets. NEVER commit a filled-in .env. These placeholders are
# deliberately obvious and safe; a production deploy MUST change them.
#
#   cp .env.example .env && $EDITOR .env
#
# Generate strong tokens, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Shared secrets ----------------------------------------------------------------
# BrainConnect bearer token. Required on every BrainConnect route except GET /health.
# AgentConnect sends it as BRAINCONNECT_TOKEN to reach the memory ledger.
BRAINCONNECT_TOKEN=replace-with-a-strong-brainconnect-token

# ToolConnect bearer token. Required on every ToolConnect route (it binds 0.0.0.0).
# AgentConnect sends it as AGENTCONNECT_TOOLCONNECT_TOKEN to consult the governor.
TOOLCONNECT_AUTH_TOKEN=replace-with-a-strong-toolconnect-token

# ComputeConnect bearer token for API auth. REQUIRED if ComputeConnect binds a
# non-loopback host. Leave blank only for pure loopback dev.
COMPUTECONNECT_TOKEN=replace-with-a-strong-computeconnect-token

# --- ComputeConnect upstream engine ------------------------------------------------
# Base URL of the external llama.cpp (or OpenAI-compatible) engine ComputeConnect
# places work on. On Linux, host.docker.internal reaches the host (host-gateway is
# wired in docker-compose.yml). If the host engine is bound to loopback only, the
# container cannot reach it and ComputeConnect comes up "degraded" (its simulated
# cloud provider stays healthy) — acceptable for a control-plane-only bring-up.
COMPUTECONNECT_UPSTREAM=http://host.docker.internal:8080

# --- AgentConnect governor mode ----------------------------------------------------
# `required` = fail-closed: if ToolConnect is unreachable, tool use is DENIED.
# `advisory` = the governor is consulted and logged but an outage does not block.
# Default here is advisory so a partial bring-up is not fatal; flip to required in prod.
AGENTCONNECT_TOOLCONNECT_MODE=advisory
