# Connect full-stack deployment — environment.
#
# Copy to `.env` (docker compose reads it automatically) and replace the placeholder
# tokens with real secrets. NEVER commit a filled-in .env. These placeholders are
# deliberately obvious and safe; a production deploy MUST change them.
#
#   cp .env.example .env && $EDITOR .env
#
# Generate strong tokens, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Shared secrets ----------------------------------------------------------------
# BrainConnect bearer token. Required on every BrainConnect route except GET /health.
# AgentConnect sends it as BRAINCONNECT_TOKEN to reach the memory ledger.
BRAINCONNECT_TOKEN=replace-with-a-strong-brainconnect-token

# ToolConnect bearer token. Required on every ToolConnect route (it binds 0.0.0.0).
# AgentConnect sends it as AGENTCONNECT_TOOLCONNECT_TOKEN to consult the governor.
TOOLCONNECT_AUTH_TOKEN=replace-with-a-strong-toolconnect-token

# ComputeConnect bearer token for API auth. REQUIRED if ComputeConnect binds a
# non-loopback host. Leave blank only for pure loopback dev.
COMPUTECONNECT_TOKEN=replace-with-a-strong-computeconnect-token

# --- ComputeConnect upstream engine ------------------------------------------------
# Base URL of the external llama.cpp (or OpenAI-compatible) engine ComputeConnect
# places work on. On Linux, host.docker.internal reaches the host (host-gateway is
# wired in docker-compose.yml). If the host engine is bound to loopback only, the
# container cannot reach it and ComputeConnect comes up "degraded" (its simulated
# cloud provider stays healthy) — acceptable for a control-plane-only bring-up.
COMPUTECONNECT_UPSTREAM=http://host.docker.internal:8080

# --- AgentConnect governor mode ----------------------------------------------------
# `required` = fail-closed: if ToolConnect is unreachable, tool use is DENIED.
# `advisory` = the governor is consulted and logged but an outage does not block.
# Default here is advisory so a partial bring-up is not fatal; flip to required in prod.
AGENTCONNECT_TOOLCONNECT_MODE=advisory

# --- sandbox-worker (deploy/sandbox-worker/) ---------------------------------------
# Reuses BRAINCONNECT_TOKEN / TOOLCONNECT_AUTH_TOKEN / COMPUTECONNECT_TOKEN above —
# no separate tokens needed. The vars below are host paths/names, not secrets; the
# defaults baked into sandbox_adapter.py already match a typical single-host layout,
# override only if yours differs.

# Shared git workspace the sandbox worker checks out `acw/<subtask_id>` worktrees
# from, and (when AUTO_MERGE is on) merges completed subtasks back into.
WORKSPACE_DIR=/home/mini/connect-workspace
# Where per-subtask worktrees are created (siblings, one dir per subtask_id).
WORKTREES_DIR=/home/mini/connect-workspace-worktrees
# Local checkout of the mcp-agentconnect monorepo, used by run.sh to stage
# agentconnect-core/-model-manager/-runtime into the Docker build context
# (these packages are not published to PyPI).
MONOREPO_DIR=/home/mini/mcp-agentconnect
# Image tag built by run.sh / referenced by sandbox_adapter.py's `docker run`.
CONNECT_WORKER_IMAGE=connect-worker:m1
# Docker network the sandbox container attaches to, to reach ComputeConnect
# (must be the same network the `connect` compose stack's services are on).
CONNECT_NETWORK=connect_default
# Compose-internal URL the sandbox *container* uses to reach ComputeConnect
# (different from AGENTCONNECT_COMPUTE_URL above, which is the host-loopback
# URL other host-side scripts use).
COMPUTECONNECT_CONTAINER_URL=http://computeconnect:8090/v1
# uid the sandbox container runs as (non-root); the adapter grants this uid
# write access to each worktree via setfacl (falls back to chmod o+w).
CONTAINER_UID=10001

# Auto-commit-and-merge: 1/true (default) = after a subtask succeeds, commit its
# worktree onto acw/<subtask_id> and merge that branch into WORKSPACE_MAIN_BRANCH
# (fast-forward if possible, else --no-ff; a conflict aborts the merge and leaves
# the branch unmerged — nothing is ever force-merged). 0/false = commit only,
# leave the branch for manual review.
AUTO_MERGE=1
WORKSPACE_MAIN_BRANCH=main
